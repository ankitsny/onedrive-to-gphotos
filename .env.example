# ─── OneDrive (Microsoft Azure) ───────────────────────────────
# Get this from: https://portal.azure.com → App registrations
ONEDRIVE_CLIENT_ID=your_azure_app_client_id_here

# ─── Google Photos (Google Cloud Console) ─────────────────────
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# optional
GOOGLE_ALBUM_NAME="From OneDrive"

# optional
# MAX_FILE_SIZE_MB=500
